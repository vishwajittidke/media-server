# Deployment Environment Variables
PROJECT_NAME="Media Server API"
SECRET_KEY="generate_a_secure_random_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (Supabase PostgreSQL Connection String)
# Example: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
DATABASE_URL="sqlite:///../database/photodb.sqlite"

# Media Storage (Cloudinary URL)
# Example: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=""

# Frontend URL (For CORS)
# Example: https://your-app.vercel.app
FRONTEND_URL="http://localhost:5173"
